{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=ViewStreamDb;Trusted_Connection=yes;TrustServerCertificate=True;"
  },
  "App": {
    "BaseUrl": "https://localhost:7163"
  },
  "Jwt": {
    "Key": "SuperSecretViewStreamJwtKey2024!@#$%^&*()_+LongEnoughForHS256",
    "Issuer": "ViewStream",
    "Audience": "ViewStream",
    "ExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 7,
    "ValidateIssuer": true,
    "ValidateAudience": true,
    "ValidateLifetime": true,
    "ValidateIssuerSigningKey": true,
    "ClockSkewSeconds": 0,
    "Algorithm": "HmacSha256",
    "RefreshTokenLength": 32,
    "AllowMultipleDevices": false,
    "NameClaimType": "name",
    "RoleClaimType": "role"
  },
  "Swagger": {
    "Title": "ViewStream API",
    "Version": "v5",
    "Description": "Clean Architecture API with JWT Authentication",
    "ContactName": "API Support",
    "ContactEmail": "support@ViewStream.com",
    "ContactUrl": "https://github.com/yourrepo",
    "LicenseName": "MIT License",
    "LicenseUrl": "https://opensource.org/licenses/MIT",
    "TermsOfServiceUrl": "",
    "EnableJwtAuthentication": true,
    "EnableXmlComments": true,
    "EnableTryItOutByDefault": true,
    "EnableDeepLinking": false,
    "EnableDisplayRequestDuration": true,
    "DefaultModelsExpandDepth": -1,
    "RoutePrefix": "swagger"
  },
  "Database": {
    "CommandTimeout": 30,
    "MaxRetryCount": 3,
    "EnableDetailedErrors": false,
    "EnableSensitiveDataLogging": false
  },
  "Email": {
    "SmtpServer": "smtp.gmail.com",
    "SmtpPort": 587,
    "SmtpUsername": "Khaledawad7654321@gmail.com",
    "SmtpPassword": "bofo kjdn fpjs qncp",
    "FromEmail": "Khaledawad7654321@gmail.com",
    "FromName": "ViewStrem System",
    "ReplyToEmail": "Khaledawad7654321@gmail.com",
    "EnableSsl": true,
    "UseDefaultCredentials": false,
    "Timeout": 10000,
    "MaxRetryCount": 3,
    "RetryDelaySeconds": 5,
    "EnableEmailLogging": true,
    "WelcomeEmailSubject": "Welcome to ViewStrem",
    "ResetPasswordSubject": "Reset Your Password",
    "VerificationEmailSubject": "Verify Your Email Address",
    "BccEmail": "",
    "CcEmail": ""
  },
  "Cache": {
    "Type": "Memory",
    "DefaultExpirationMinutes": 30,
    "SlidingExpirationMinutes": 10,
    "CacheSizeLimit": 100
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:4200",
      "https://localhost:3000"
    ],
    "AllowedMethods": [
      "GET",
      "POST",
      "PUT",
      "DELETE",
      "OPTIONS"
    ],
    "AllowedHeaders": [
      "Content-Type",
      "Authorization",
      "X-Requested-With"
    ],
    "AllowCredentials": true
  },
  "RateLimit": {
    "PermitLimit": 100,
    "QueueLimit": 0,
    "WindowMinutes": 1,
    "AutoReplenishment": true
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": "Information",
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {SourceContext} - {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "Properties": {
      "Application": "ViewStream.API"
    }
  },
  "RateLimiting": {
    "AuthPermitLimit": 5,
    "AuthWindowSeconds": 60,
    "SearchPermitLimit": 30,
    "SearchWindowSeconds": 60,
    "PublicReadPermitLimit": 100,
    "PublicReadWindowSeconds": 60,
    "UserWriteRateLimit": 20,
    "UserWriteWindowSeconds": 60,
    "ReportRateLimit": 3,
    "ReportWindowSeconds": 60,
    "AdminRateLimit": 50,
    "AdminWindowSeconds": 60,
    "AnalyticsRateLimit": 200,
    "AnalyticsWindowSeconds": 60,
    "ContentManagementRateLimit": 30,
    "ContentManagementWindowSeconds": 60,
    "DefaultRateLimit": 20,
    "DefaultRateLimitWindowSeconds": 60
  },
