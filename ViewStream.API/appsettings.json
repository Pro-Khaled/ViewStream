{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=ViewStreamDb;Trusted_Connection=yes;TrustServerCertificate=True;"
  },
  "Jwt": {
    "Key": "YourSuperSecretKeyThatIsAtLeast32CharactersLong!",
    "Issuer": "ViewStream",
    "Audience": "ViewStream",
    "ExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 7,
    "ValidateIssuer": true,
    "ValidateAudience": true,
    "ValidateLifetime": true,
    "ValidateIssuerSigningKey": true,
    "ClockSkewSeconds": 0,
    "Algorithm": "HmacSha256",
    "RefreshTokenLength": 32,
    "AllowMultipleDevices": false,
    "NameClaimType": "name",
    "RoleClaimType": "role"
  },
  "Swagger": {
    "Title": "ViewStream API",
    "Version": "v5",
    "Description": "Clean Architecture API with JWT Authentication",
    "ContactName": "API Support",
    "ContactEmail": "support@ViewStream.com",
    "ContactUrl": "https://github.com/yourrepo",
    "LicenseName": "MIT License",
    "LicenseUrl": "https://opensource.org/licenses/MIT",
    "TermsOfServiceUrl": "",
    "EnableJwtAuthentication": true,
    "EnableXmlComments": false,
    "EnableTryItOutByDefault": true,
    "EnableDeepLinking": false,
    "EnableDisplayRequestDuration": true,
    "DefaultModelsExpandDepth": -1,
    "RoutePrefix": "swagger"
  },
  "Database": {
    "CommandTimeout": 30,
    "MaxRetryCount": 3,
    "EnableDetailedErrors": false,
    "EnableSensitiveDataLogging": false
  },
  "Email": {
    "SmtpServer": "smtp.gmail.com",
    "SmtpPort": 587,
    "SmtpUsername": "your-email@gmail.com",
    "SmtpPassword": "your-app-password",
    "FromEmail": "noreply@AppAuto6.com",
    "FromName": "AppAuto6 System",
    "ReplyToEmail": "support@AppAuto6.com",
    "EnableSsl": true,
    "UseDefaultCredentials": false,
    "Timeout": 10000,
    "MaxRetryCount": 3,
    "RetryDelaySeconds": 5,
    "EnableEmailLogging": true,
    "WelcomeEmailSubject": "Welcome to AppAuto6",
    "ResetPasswordSubject": "Reset Your Password",
    "VerificationEmailSubject": "Verify Your Email Address",
    "BccEmail": "",
    "CcEmail": ""
  },
  "Cache": {
    "Type": "Memory",
    "DefaultExpirationMinutes": 30,
    "SlidingExpirationMinutes": 10,
    "CacheSizeLimit": 100
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:4200",
      "https://localhost:3000"
    ],
    "AllowedMethods": [
      "GET",
      "POST",
      "PUT",
      "DELETE",
      "OPTIONS"
    ],
    "AllowedHeaders": [
      "Content-Type",
      "Authorization",
      "X-Requested-With"
    ],
    "AllowCredentials": true
  },
  "RateLimit": {
    "PermitLimit": 100,
    "QueueLimit": 0,
    "WindowMinutes": 1,
    "AutoReplenishment": true
  }
}